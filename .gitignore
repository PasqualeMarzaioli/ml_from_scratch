# .gitignore — Excludes local environments, caches, and generated noise.
# It keeps source files and intentional outputs visible in version control.
# Author: Pasquale Marzaioli

.DS_Store
.cache/
.matplotlib/
.pytest_cache/
.ruff_cache/
.venv/
**/.ipynb_checkpoints/
*.egg-info/
*.pyc
__pycache__/
build/
coverage.xml
dist/
htmlcov/
plots/*
!plots/
!plots/linear_regression_fit.png
!plots/polynomial_regression_fit.png
!plots/logistic_regression_fit.png
!plots/sklearn_comparison.png
